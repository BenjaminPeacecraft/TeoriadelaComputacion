import javax.swing.*;
import java.awt.*;
import java.util.*;
import java.util.List;

public class AppOperaciones extends JFrame {
    private JTextField txtCadena;
    private JTextArea areaResultados1;
    
    private JTextField txtAlfabeto, txtLimite;
    private JTextArea areaResultados2;

    public AppOperaciones() {
        setTitle("Desarrollo de Interfaz Gráfica - Operaciones Básicas");
        setSize(600, 300);
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setLayout(new BorderLayout());

        JTabbedPane tabs = new JTabbedPane();

        //PANEL EJERCICIO 1
        JPanel p1 = new JPanel(new BorderLayout(10, 10));
        p1.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
        
        JPanel inputP1 = new JPanel(new GridLayout(2, 1));
        inputP1.add(new JLabel("Ingresa una cadena:"));
        txtCadena = new JTextField();
        inputP1.add(txtCadena);
        
        areaResultados1 = new JTextArea();
        areaResultados1.setEditable(false);
        
        JButton btnCalc1 = new JButton("Calcular Subcadenas/Prefijos/Sufijos");
        btnCalc1.addActionListener(e -> calcularCadenas());

        p1.add(inputP1, BorderLayout.NORTH);
        p1.add(new JScrollPane(areaResultados1), BorderLayout.CENTER);
        p1.add(btnCalc1, BorderLayout.SOUTH);

        //PANEL EJERCICIO 2
        JPanel p2 = new JPanel(new BorderLayout(10, 10));
        p2.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
        
        JPanel inputP2 = new JPanel(new GridLayout(4, 1));
        inputP2.add(new JLabel("Alfabeto (separado por comas, ej: a,b):"));
        txtAlfabeto = new JTextField();
        inputP2.add(txtAlfabeto);
        inputP2.add(new JLabel("Longitud Máxima:"));
        txtLimite = new JTextField("3");
        inputP2.add(txtLimite);
       	
        areaResultados2 = new JTextArea();
        areaResultados2.setEditable(false);
        
        JButton btnCalc2 = new JButton("Generar Cerraduras");
        btnCalc2.addActionListener(e -> calcularCerraduras());

        p2.add(inputP2, BorderLayout.NORTH);
        p2.add(new JScrollPane(areaResultados2), BorderLayout.CENTER);
        p2.add(btnCalc2, BorderLayout.SOUTH);



        tabs.addTab("Subcadenas/Prefijos/Sufijos", p1);
        tabs.addTab("Cerradura de Kleene y Positiva", p2);

        add(tabs, BorderLayout.CENTER);
    }

    private void calcularCadenas() {
        String s = txtCadena.getText();
        if (s.isEmpty()) return;

        Set<String> prefijos = new TreeSet<>(Comparator.comparingInt(String::length).thenComparing(s2 -> s2));
        Set<String> sufijos = new TreeSet<>(Comparator.comparingInt(String::length).thenComparing(s2 -> s2));
        Set<String> subs = new TreeSet<>(Comparator.comparingInt(String::length).thenComparing(s2 -> s2));

        for (int i = 0; i <= s.length(); i++) {
            prefijos.add(s.substring(0, i));
            sufijos.add(s.substring(i));
            for (int j = i + 1; j <= s.length(); j++) {
                subs.add(s.substring(i, j));
            }
        }

        areaResultados1.setText("PREFIJOS: " + prefijos + "\n\n" +
                               "SUFIJOS: " + sufijos + "\n\n" +
                               "SUBCADENAS: " + subs);
    }

    private void calcularCerraduras() {
        String[] sigma = txtAlfabeto.getText().replace(" ", "").split(",");
        int max;
        try { max = Integer.parseInt(txtLimite.getText()); } catch(Exception e) { max = 0; }

        List<String> kleene = new ArrayList<>();
        kleene.add("λ");
        
        List<String> actual = new ArrayList<>(Arrays.asList(sigma));
        if (max >= 1) kleene.addAll(actual);

        for (int i = 2; i <= max; i++) {
            List<String> siguiente = new ArrayList<>();
            for (String s : actual) {
                for (String letra : sigma) {
                    siguiente.add(s + letra);
                }
            }
            kleene.addAll(siguiente);
            actual = siguiente;
        }

        String resK = String.join(", ", kleene);
        String resP = resK.replace("λ, ", "");

        areaResultados2.setText("KLEENE (Σ*):\n" + resK + "\n\n" +
                               "POSITIVA (Σ+):\n" + resP);
    }


    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new AppOperaciones().setVisible(true));
    }
}
