import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.io.*;
import java.util.*;

public class OperacionesLenguajes extends JFrame {

    // Componentes para subcadenas
    private JTextField cadenaInput;
    private JTextArea resultadoSub;

    // Componentes para cerraduras
    private JTextField alfabetoInput;
    private JTextField longitudInput;
    private JTextArea resultadoCerradura;

    public OperacionesLenguajes() {

        setTitle("Operaciones con Lenguajes Formales");
        setSize(700,500);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        JTabbedPane pestañas = new JTabbedPane();

        pestañas.add("Subcadenas / Prefijos / Sufijos", panelSubcadenas());
        pestañas.add("Cerradura de Kleene y Positiva", panelCerraduras());

        add(pestañas);

        setVisible(true);
    }

    // PANEL 1
    private JPanel panelSubcadenas() {

        JPanel panel = new JPanel(new BorderLayout());

        JPanel entrada = new JPanel();
        entrada.add(new JLabel("Ingrese cadena:"));
        cadenaInput = new JTextField(20);
        entrada.add(cadenaInput);

        JButton calcular = new JButton("Calcular");
        entrada.add(calcular);

        JButton guardar = new JButton("Guardar en TXT");
        entrada.add(guardar);

        panel.add(entrada, BorderLayout.NORTH);

        resultadoSub = new JTextArea();
        JScrollPane scroll = new JScrollPane(resultadoSub);

        panel.add(scroll, BorderLayout.CENTER);

        calcular.addActionListener(e -> calcularSubcadenas());
        guardar.addActionListener(e -> guardarArchivo(resultadoSub.getText()));

        return panel;
    }

    // PANEL 2
    private JPanel panelCerraduras() {

        JPanel panel = new JPanel(new BorderLayout());

        JPanel entrada = new JPanel();

        entrada.add(new JLabel("Alfabeto (ej: abc):"));
        alfabetoInput = new JTextField(10);
        entrada.add(alfabetoInput);

        entrada.add(new JLabel("Longitud máxima:"));
        longitudInput = new JTextField(5);
        entrada.add(longitudInput);

        JButton generar = new JButton("Generar");
        entrada.add(generar);

        JButton guardar = new JButton("Exportar TXT");
        entrada.add(guardar);

        panel.add(entrada, BorderLayout.NORTH);

        resultadoCerradura = new JTextArea();
        JScrollPane scroll = new JScrollPane(resultadoCerradura);

        panel.add(scroll, BorderLayout.CENTER);

        generar.addActionListener(e -> generarCerraduras());
        guardar.addActionListener(e -> guardarArchivo(resultadoCerradura.getText()));

        return panel;
    }

    // SUBCADENAS
    private void calcularSubcadenas() {

        String cadena = cadenaInput.getText();
        StringBuilder salida = new StringBuilder();

        salida.append("Prefijos:\n");

        for(int i=1;i<=cadena.length();i++){
            salida.append(cadena.substring(0,i)).append("\n");
        }

        salida.append("\nSufijos:\n");

        for(int i=0;i<cadena.length();i++){
            salida.append(cadena.substring(i)).append("\n");
        }

        salida.append("\nSubcadenas:\n");

        for(int i=0;i<cadena.length();i++){
            for(int j=i+1;j<=cadena.length();j++){
                salida.append(cadena.substring(i,j)).append("\n");
            }
        }

        resultadoSub.setText(salida.toString());
    }

    // CERRADURAS
    private void generarCerraduras(){

        String alfabeto = alfabetoInput.getText();
        int max = Integer.parseInt(longitudInput.getText());

        Set<String> kleene = new LinkedHashSet<>();
        Set<String> positiva = new LinkedHashSet<>();

        generar("", alfabeto, max, kleene);

        for(String s : kleene){
            if(!s.equals(""))
                positiva.add(s);
        }

        StringBuilder salida = new StringBuilder();

        salida.append("Cerradura de Kleene (Σ*):\n");
        for(String s : kleene){
            salida.append(s).append("\n");
        }

        salida.append("\nCerradura Positiva (Σ+):\n");
        for(String s : positiva){
            salida.append(s).append("\n");
        }

        resultadoCerradura.setText(salida.toString());
    }

    private void generar(String actual, String alfabeto, int max, Set<String> conjunto){

        if(actual.length() > max)
            return;

        conjunto.add(actual);

        for(char c : alfabeto.toCharArray()){
            generar(actual + c, alfabeto, max, conjunto);
        }
    }

    // GUARDAR ARCHIVO
    private void guardarArchivo(String contenido){

        JFileChooser file = new JFileChooser();

        if(file.showSaveDialog(this) == JFileChooser.APPROVE_OPTION){

            try{
                FileWriter writer = new FileWriter(file.getSelectedFile());
                writer.write(contenido);
                writer.close();

                JOptionPane.showMessageDialog(this,"Archivo guardado correctamente");

            }catch(IOException e){
                e.printStackTrace();
            }
        }
    }

    public static void main(String[] args) {
        new OperacionesLenguajes();
    }
}
